# Kaiju Arcade — Example Environment Variables
#
# Copy this file to .env and fill in values for your environment.
# Lines marked [SECRET] should never be committed to source control.
# Lines marked [NON-SECRET] are safe to commit as team defaults.
#
# All variables are read and validated at startup by src/ops/config.ts.
# The process exits with code 1 in production if PORT or HOST are absent.

# ---------------------------------------------------------------------------
# Server Identity and Binding
# ---------------------------------------------------------------------------

# [NON-SECRET] TCP port the HTTP/WebSocket server binds to.
# Required explicitly when NODE_ENV=production (no default).
# Example: 8080 for container deployments.
PORT=3000

# [NON-SECRET] Network interface the server binds to.
# Required explicitly when NODE_ENV=production (no default).
# Set to 0.0.0.0 in containers so health probes can reach the process.
HOST=localhost

# [NON-SECRET] Runtime environment name.
# Accepted values: development | staging | production
# Controls Express optimizations and startup validation strictness.
NODE_ENV=development

# ---------------------------------------------------------------------------
# Lifecycle and Session Control
# ---------------------------------------------------------------------------

# [NON-SECRET] Milliseconds allowed for in-flight sessions to finish during
# graceful SIGTERM shutdown. Increase for high-latency matches.
DRAIN_TIMEOUT_MS=30000

# [NON-SECRET] Reconnection grace window forwarded to allowReconnection() in
# MatchRoom. Clients have this many milliseconds to reconnect after a drop.
RECONNECT_GRACE_MS=30000

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------

# [NON-SECRET] Enables the Prometheus-compatible /metrics endpoint.
# Accepted values: true | false
METRICS_ENABLED=false

# [NON-SECRET] Minimum log severity to emit.
# Accepted values: debug | info | warn | error
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------------------

# [NON-SECRET] Maximum join requests per minute per IP address.
# Applies to the Colyseus join path (Phase 5).
RATE_LIMIT_JOIN_RPM=60

# [NON-SECRET] Maximum match-create requests per minute per IP address.
# Applies to POST /api/matches (Phase 5).
RATE_LIMIT_CREATE_RPM=10

# ---------------------------------------------------------------------------
# Release and Feature Control
# ---------------------------------------------------------------------------

# [NON-SECRET] Active rollout stage for progressive delivery guards.
# Accepted values: canary | stable
RELEASE_STAGE=stable

# [NON-SECRET] Kill switch for Commander dispatch routing.
# Set to false to disable all commander.dispatch messages without a redeploy.
# See docs/operations/feature-flags.md for recovery steps.
FEATURE_DISPATCH_ENABLED=true

# [NON-SECRET] Kill switch for the 20 Hz game-loop tick broadcast.
# Set to false to freeze world-state updates without disconnecting players.
# See docs/operations/feature-flags.md for recovery steps.
FEATURE_TICK_BROADCAST_ENABLED=true
